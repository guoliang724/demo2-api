{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET Core Launch (watch)",
      "type": "coreclr",
      "request": "launch",
      "program": "dotnet",
      "args": ["watch", "run", "--project", "${workspaceFolder}"],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Now listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    }
  ]
}
